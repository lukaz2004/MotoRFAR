<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.vagell.kv4pht.ui.MainViewModel" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg"
        tools:context="com.vagell.kv4pht.ui.MainActivity"
        android:fitsSystemWindows="true">

        <!-- Círculo RX -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/rxAudioCircle"
                android:contentDescription="@string/visualization_of_current_receive_audio_volume_display"
                android:layout_height="0dp"
                android:layout_width="0dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/circle_rx"
                android:focusable="false"
                android:importantForAccessibility="no"/>
        </androidx.appcompat.widget.LinearLayoutCompat>

        <!-- Círculo TX -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="bottom">
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:id="@+id/txAudioCircle"
                    android:contentDescription="@string/visualization_of_current_transmit_audio_volume"
                    android:layout_height="0dp"
                    android:layout_width="0dp"
                    android:src="@drawable/circle_tx"
                    android:focusable="false"
                    android:importantForAccessibility="no"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>

        <!-- Layout principal -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/mainTopLevelLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- ── PANEL DE FRECUENCIA ACTIVA ── -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/frequencyContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_corners"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:padding="16dp">

                <!-- Nombre del canal activo -->
                <TextView
                    android:id="@+id/activeMemoryName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/share_tech_mono"
                    android:gravity="center"
                    android:text="@string/welcome_to_display"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:maxLines="1"/>

                <!-- Frecuencia en grande — Share Tech Mono, verde brillante -->
                <EditText
                    android:id="@+id/activeFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/share_tech_mono"
                    android:gravity="center"
                    android:textColor="@color/primary"
                    android:textSize="56sp"
                    android:textStyle="bold"
                    android:text="@string/kv4p_ht"
                    android:background="@color/clear"
                    android:maxLength="8"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:inputType="numberDecimal"
                    android:layout_marginTop="-6dp"/>

                <!-- Modo — MHz · FM -->
                <TextView
                    android:id="@+id/freqModeLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/share_tech_mono"
                    android:gravity="center"
                    android:text="MHz · FM · SIMPLEX"
                    android:textColor="@color/text_ghost"
                    android:textSize="9sp"
                    android:letterSpacing="0.15"
                    android:layout_marginTop="-4dp"
                    android:layout_marginBottom="4dp"/>

                <!-- Fila: banda + S-meter -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="24dp">

                    <EditText
                        android:id="@+id/activeBand"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/clear"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="end"
                        android:inputType="none"
                        android:longClickable="false"
                        android:text="@string/vhf"
                        android:textColor="@color/accent"
                        android:textIsSelectable="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="invisible"
                        android:layout_marginEnd="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/sMeter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <View android:id="@+id/sMeter1" android:layout_width="14dp" android:layout_height="3dp"  android:layout_marginEnd="5dp" android:background="@color/accent" android:alpha="0.3" />
                        <View android:id="@+id/sMeter2" android:layout_width="14dp" android:layout_height="5dp"  android:layout_marginEnd="5dp" android:background="@color/accent" android:alpha="0.3" />
                        <View android:id="@+id/sMeter3" android:layout_width="14dp" android:layout_height="7dp"  android:layout_marginEnd="5dp" android:background="@color/accent" android:alpha="0.3" />
                        <View android:id="@+id/sMeter4" android:layout_width="14dp" android:layout_height="9dp"  android:layout_marginEnd="5dp" android:background="@color/accent" android:alpha="0.3" />
                        <View android:id="@+id/sMeter5" android:layout_width="14dp" android:layout_height="11dp" android:layout_marginEnd="5dp" android:background="@color/accent" android:alpha="0.3" />
                        <View android:id="@+id/sMeter6" android:layout_width="14dp" android:layout_height="13dp" android:layout_marginEnd="5dp" android:background="@color/accent" android:alpha="0.3" />
                        <View android:id="@+id/sMeter7" android:layout_width="14dp" android:layout_height="15dp" android:layout_marginEnd="5dp" android:background="@color/accent" android:alpha="0.3" />
                        <View android:id="@+id/sMeter8" android:layout_width="14dp" android:layout_height="17dp" android:layout_marginEnd="5dp" android:background="@color/accent" android:alpha="0.3" />
                        <View android:id="@+id/sMeter9" android:layout_width="14dp" android:layout_height="19dp" android:background="@color/accent" android:alpha="0.3" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- ── SELECTOR DE GRUPO + MENÚ ── -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/voiceModeLineHolder"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/primary_deselected"
                    android:alpha="0.4"/>

                <TextView
                    android:id="@+id/groupSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="0"
                    android:fontFamily="@font/jost"
                    android:text="@string/all_memories_display1"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:onClick="groupSelectorClicked" />

                <ImageButton
                    android:id="@+id/moreButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="@drawable/ic_menu"
                    android:contentDescription="@string/settings_display"
                    android:onClick="moreClicked" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/primary_deselected"
                    android:alpha="0.4"/>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- ── LISTA DE CANALES ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/memoriesList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="0"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clipToPadding="false"/>

            <!-- ── CONTROLES VOZ: alertas + PTT ── -->
            <LinearLayout
                android:id="@+id/voiceModeBottomControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/scanButton"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:onClick="scanClicked" />

                <!-- EMERGENCIA — ancho completo, primero -->
                <Button
                    android:id="@+id/emergencyAlertButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="6dp"
                    android:text="⚠  EMERGENCIA  —  Solicitar asistencia"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:fontFamily="@font/share_tech_mono"
                    android:background="@drawable/btn_emergency"
                    android:onClick="emergencyAlertClicked"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"/>

                <!-- Fila: DETENCIÓN + REAGRUPAR debajo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <Button
                        android:id="@+id/stopAlertButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="DETENCIÓN"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1a0e00"
                        android:textAllCaps="false"
                        android:fontFamily="@font/share_tech_mono"
                        android:background="@drawable/btn_stop"
                        android:onClick="stopAlertClicked"
                        android:stateListAnimator="@null"
                        android:elevation="0dp"/>

                    <Button
                        android:id="@+id/regroupAlertButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="REAGRUPAR"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:fontFamily="@font/share_tech_mono"
                        android:background="@drawable/btn_regroup"
                        android:onClick="regroupAlertClicked"
                        android:stateListAnimator="@null"
                        android:elevation="0dp"/>

                </LinearLayout>

                <!-- PTT centrado debajo de alertas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingBottom="8dp">

                    <ImageButton
                        android:id="@+id/pttButton"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:background="@drawable/ptt_button"
                        android:elevation="8dp"
                        android:contentDescription="@string/push_to_talk_display"
                        android:clickable="false" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── MODO CHAT APRS ── -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/textModeContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/rounded_corners"
                android:visibility="gone"
                android:paddingTop="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/aprsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/primary_deselected"
                    android:alpha="0.4"/>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost"
                        android:text="@string/to_display"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:layout_weight="0"/>

                    <EditText
                        android:id="@+id/textChatTo"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:maxLength="10"
                        android:minLines="1"
                        android:background="@android:color/transparent"
                        android:textColorHint="@color/primary_deselected"
                        android:hint="@string/callsign_or_cq"
                        android:text="@string/cq"
                        android:imeOptions="actionDone"/>

                    <ImageButton
                        android:id="@+id/singleBeaconButton"
                        android:alpha="0.8"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_pin"
                        android:contentDescription="@string/send_aprs_position_beacond_display"
                        android:onClick="singleBeaconButtonClicked"/>

                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/textChatInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:maxLength="67"
                        android:minLines="1"
                        android:maxLines="2"
                        android:background="@android:color/transparent"
                        android:textColorHint="@color/primary_deselected"
                        android:hint="@string/write_up_to_67_chars"
                        android:layout_marginEnd="12dp"
                        android:imeOptions="actionSend"/>

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp">
                        <ImageButton
                            android:id="@+id/sendButton"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:background="@drawable/ic_send"
                            android:contentDescription="@string/send_message_display"
                            android:onClick="sendTextClicked"/>
                        <View
                            android:id="@+id/sendButtonOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:onClick="sendButtonOverlayClicked"/>
                    </FrameLayout>

                </androidx.appcompat.widget.LinearLayoutCompat>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- ── BARRA DE NAVEGACIÓN INFERIOR ── -->
            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottomNavigationView"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                app:menu="@menu/bottom_nav_menu"
                app:itemTextColor="@color/bottom_nav_text"
                app:itemIconTint="@color/bottom_nav_icon"
                app:itemActiveIndicatorStyle="@style/Theme.BottomNavigationView.ActiveIndicator"
                android:background="@color/surface_variant"/>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </FrameLayout>
</layout>
