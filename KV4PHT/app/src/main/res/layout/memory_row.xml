<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:id="@+id/memoryContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/memory_row_min_height"
        android:orientation="vertical"
        android:background="@drawable/memory_channel_bg"
        android:gravity="center_vertical"
        android:padding="@dimen/memory_row_padding">

        <View
            android:id="@+id/memoryMenu"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

        <!-- Nombre del canal -->
        <TextView
            android:id="@+id/memoryName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_channel_name"
            android:textColor="@color/text_dim"
            android:fontFamily="@font/share_tech_mono"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Frecuencia — verde brillante, monospace grande -->
        <TextView
            android:id="@+id/memoryFrequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:fontFamily="@font/share_tech_mono"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

</LinearLayout>
