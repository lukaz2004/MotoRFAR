<?xml version="1.0" encoding="utf-8"?>
<!--
    Restricción de red: solo HTTPS, solo al dominio de RepeaterBook.
    La app no tiene backend propio — toda comunicación es por RF.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">repeaterbook.com</domain>
    </domain-config>
    <!-- Android 7.0 (API 24) no trae ISRG Root X1 de fábrica (recién en 7.1.1).
         GitHub/Fastly usa Let's Encrypt, y sin este anchor la cadena TLS no valida
         en esos equipos aunque el resto de la app (tiles OSM, etc.) ande bien. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">githubusercontent.com</domain>
        <domain includeSubdomains="true">github.com</domain>
        <!-- brouter.de (tiles de ruteo, ver ar.motorfar.app.nav) tambien es Let's Encrypt. -->
        <domain includeSubdomains="true">brouter.de</domain>
        <!-- nominatim.openstreetmap.org (buscador de direcciones) tambien es Let's Encrypt. -->
        <domain includeSubdomains="true">nominatim.openstreetmap.org</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="@raw/isrg_root_x1" />
        </trust-anchors>
    </domain-config>
</network-security-config>
