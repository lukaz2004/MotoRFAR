<?xml version="1.0" encoding="utf-8"?>
<!--
    Reglas de backup para Android 11 y anteriores (pre-API 31).
    Excluye la DB Room y las SharedPreferences con datos de posición GPS.
-->
<full-backup-content>
    <exclude domain="database" path="kv4pht-db" />
    <exclude domain="database" path="kv4pht-db-shm" />
    <exclude domain="database" path="kv4pht-db-wal" />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
