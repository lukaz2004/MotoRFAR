<?xml version="1.0" encoding="utf-8"?>
<!--
    Exclusiones de backup para Android 12+ (API 31+).
    La DB Room contiene posiciones GPS, callsigns y mensajes APRS — no se respalda.
    Las SharedPreferences contienen el callsign y configuración de TX.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="kv4pht-db" />
        <exclude domain="database" path="kv4pht-db-shm" />
        <exclude domain="database" path="kv4pht-db-wal" />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="kv4pht-db" />
        <exclude domain="database" path="kv4pht-db-shm" />
        <exclude domain="database" path="kv4pht-db-wal" />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
