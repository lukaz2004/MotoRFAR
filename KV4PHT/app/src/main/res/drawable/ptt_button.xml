<?xml version="1.0" encoding="utf-8"?>
<!-- PTT inactivo — gradiente radial verde, efecto convexo -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sombra exterior -->
    <item android:top="5dp" android:left="5dp">
        <shape android:shape="oval">
            <solid android:color="@color/ptt_shadow"/>
        </shape>
    </item>
    <!-- Borde exterior luminoso -->
    <item android:bottom="4dp" android:right="4dp">
        <shape android:shape="oval">
            <solid android:color="@color/primary"/>
        </shape>
    </item>
    <!-- Cuerpo con gradiente radial (simula convexo) -->
    <item android:bottom="6dp" android:right="6dp" android:top="2dp" android:left="2dp">
        <shape android:shape="oval">
            <gradient android:type="radial"
                android:gradientRadius="50%p"
                android:startColor="@color/primary"
                android:centerColor="@color/accent"
                android:endColor="@color/text_faint"/>
        </shape>
    </item>
</layer-list>
