<?xml version="1.0" encoding="utf-8"?>
<!-- Botón EMERGENCIA con relieve 3D — colores siempre rojo, no cambian con el tema -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sombra inferior (da sensación de profundidad) -->
    <item android:top="4dp">
        <shape>
            <solid android:color="@color/emergency_shadow"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
    <!-- Cuerpo del botón con gradiente -->
    <item android:bottom="3dp">
        <shape>
            <gradient android:type="linear" android:angle="270"
                android:startColor="@color/emergency_highlight"
                android:centerColor="@color/emergency_border"
                android:endColor="@color/emergency_dark"/>
            <corners android:radius="6dp"/>
            <stroke android:width="1dp" android:color="@color/emergency_highlight"/>
        </shape>
    </item>
</layer-list>
