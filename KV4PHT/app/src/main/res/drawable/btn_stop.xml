<?xml version="1.0" encoding="utf-8"?>
<!-- Botón DETENCIÓN (naranja táctico) con relieve -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="4dp">
        <shape>
            <solid android:color="@color/stop_shadow"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape>
            <gradient android:type="linear" android:angle="270"
                android:startColor="@color/stop_highlight"
                android:centerColor="@color/stop_center"
                android:endColor="@color/stop_dark"/>
            <corners android:radius="6dp"/>
            <stroke android:width="1dp" android:color="@color/stop_highlight"/>
        </shape>
    </item>
</layer-list>
