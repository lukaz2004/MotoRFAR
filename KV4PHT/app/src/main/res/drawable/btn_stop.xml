<?xml version="1.0" encoding="utf-8"?>
<!-- Botón DETENCIÓN (naranja) con relieve -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="4dp">
        <shape>
            <solid android:color="#2a0c04"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape>
            <gradient android:type="linear" android:angle="270"
                android:startColor="#F5C4B3"
                android:centerColor="#D85A30"
                android:endColor="#993C1D"/>
            <corners android:radius="6dp"/>
            <stroke android:width="1dp" android:color="#F5C4B3"/>
        </shape>
    </item>
</layer-list>
