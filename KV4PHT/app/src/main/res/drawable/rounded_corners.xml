<?xml version="1.0" encoding="utf-8"?>
<!-- Panel principal — fondo oscuro con gradiente y borde verde sutil -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient android:type="linear" android:angle="270"
                android:startColor="#0a1a0a"
                android:endColor="#030804"/>
            <stroke android:width="1dp" android:color="#1f3a1f"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- Línea superior luminosa (highlight) -->
    <item android:bottom="2dp">
        <shape>
            <gradient android:type="linear" android:angle="270"
                android:startColor="#1f3a1f"
                android:endColor="#00000000"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
