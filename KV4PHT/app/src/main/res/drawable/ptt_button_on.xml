<?xml version="1.0" encoding="utf-8"?>
<!-- PTT activo/presionado — más brillante -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp" android:left="2dp">
        <shape android:shape="oval">
            <solid android:color="#0c1a04"/>
        </shape>
    </item>
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="oval">
            <solid android:color="#FAC775"/>
        </shape>
    </item>
    <item android:bottom="4dp" android:right="4dp" android:top="2dp" android:left="2dp">
        <shape android:shape="oval">
            <gradient android:type="radial"
                android:gradientRadius="100%"
                android:startColor="#FFFFFF"
                android:centerColor="#8FE875"
                android:endColor="#27500A"/>
        </shape>
    </item>
</layer-list>
