<?xml version="1.0" encoding="utf-8"?>
<!-- Botón REAGRUPAR (verde) con relieve -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="4dp">
        <shape>
            <solid android:color="#0c1a04"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape>
            <gradient android:type="linear" android:angle="270"
                android:startColor="#C0DD97"
                android:centerColor="#639922"
                android:endColor="#3B6D11"/>
            <corners android:radius="6dp"/>
            <stroke android:width="1dp" android:color="#C0DD97"/>
        </shape>
    </item>
</layer-list>
