<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable name="viewModel" type="com.vagell.kv4pht.ui.MainViewModel" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg"
        tools:context="com.vagell.kv4pht.ui.MainActivity"
        android:fitsSystemWindows="true">

        <!-- Fondo animado RX/TX -->
        <ImageView android:id="@+id/rxAudioCircle" android:layout_width="0dp" android:layout_height="0dp" android:src="@drawable/circle_rx" android:contentDescription="@string/visualization_of_current_receive_audio_volume_display" android:focusable="false" android:importantForAccessibility="no"/>
        <ImageView android:id="@+id/txAudioCircle" android:layout_width="0dp" android:layout_height="0dp" android:src="@drawable/circle_tx" android:contentDescription="@string/visualization_of_current_transmit_audio_volume" android:focusable="false" android:importantForAccessibility="no"/>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/mainTopLevelLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- ── BARRA SUPERIOR COMPACTA ── -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@color/medium_gray">

                <TextView
                    android:id="@+id/activeMemoryName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MotoRFAR"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/jost"
                    android:maxLines="1"/>

                <TextView
                    android:id="@+id/groupSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/all_memories_display1"
                    android:textColor="@color/primary_deselected"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:onClick="groupSelectorClicked"/>

                <ImageButton
                    android:id="@+id/moreButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="10dp"
                    android:background="@drawable/ic_menu"
                    android:contentDescription="@string/settings_display"
                    android:onClick="moreClicked"/>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- ── CUERPO PRINCIPAL HORIZONTAL ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <!-- COLUMNA IZQUIERDA: PTT grande -->
                <LinearLayout
                    android:layout_width="130dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@color/medium_gray">

                    <ImageButton
                        android:id="@+id/pttButton"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/ptt_button"
                        android:contentDescription="@string/push_to_talk_display"
                        android:clickable="false"
                        android:elevation="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mantené\npresionado\npara TX"
                        android:textColor="@color/primary_deselected"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/jost"/>

                </LinearLayout>

                <!-- COLUMNA CENTRAL: Frecuencia + lista de canales -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <!-- Frecuencia activa -->
                    <LinearLayout
                        android:id="@+id/frequencyContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/rounded_corners"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/activeBand"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@color/clear"
                                android:cursorVisible="false"
                                android:focusable="false"
                                android:inputType="none"
                                android:text="@string/vhf"
                                android:textColor="@color/accent"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:visibility="invisible"
                                tools:visibility="visible"/>

                            <EditText
                                android:id="@+id/activeFrequency"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@color/clear"
                                android:textColor="@color/primary"
                                android:textSize="36sp"
                                android:text="---"
                                android:maxLength="8"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/jost"/>
                        </LinearLayout>

                        <!-- S-meter compacto -->
                        <LinearLayout
                            android:id="@+id/sMeter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:paddingEnd="8dp">
                            <View android:id="@+id/sMeter1" android:layout_width="10dp" android:layout_height="4dp"  android:layout_marginEnd="3dp" android:background="@color/primary" android:alpha="0.2"/>
                            <View android:id="@+id/sMeter2" android:layout_width="10dp" android:layout_height="6dp"  android:layout_marginEnd="3dp" android:background="@color/primary" android:alpha="0.2"/>
                            <View android:id="@+id/sMeter3" android:layout_width="10dp" android:layout_height="9dp"  android:layout_marginEnd="3dp" android:background="@color/primary" android:alpha="0.2"/>
                            <View android:id="@+id/sMeter4" android:layout_width="10dp" android:layout_height="12dp" android:layout_marginEnd="3dp" android:background="@color/primary" android:alpha="0.2"/>
                            <View android:id="@+id/sMeter5" android:layout_width="10dp" android:layout_height="15dp" android:layout_marginEnd="3dp" android:background="@color/primary" android:alpha="0.2"/>
                            <View android:id="@+id/sMeter6" android:layout_width="10dp" android:layout_height="18dp" android:layout_marginEnd="3dp" android:background="@color/primary" android:alpha="0.2"/>
                            <View android:id="@+id/sMeter7" android:layout_width="10dp" android:layout_height="21dp" android:layout_marginEnd="3dp" android:background="@color/primary" android:alpha="0.2"/>
                            <View android:id="@+id/sMeter8" android:layout_width="10dp" android:layout_height="24dp" android:layout_marginEnd="3dp" android:background="@color/primary" android:alpha="0.2"/>
                            <View android:id="@+id/sMeter9" android:layout_width="10dp" android:layout_height="27dp" android:background="@color/primary" android:alpha="0.2"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Lista de canales -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/memoriesList"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:clipToPadding="false"/>

                    <!-- Scan button oculto (requerido por MainActivity.java) -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/scanButton"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone"
                        android:onClick="scanClicked"/>

                    <!-- Chat APRS (oculto en landscape, se muestra al tocar tab) -->
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/textModeContainer"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/rounded_corners"
                        android:visibility="gone"
                        android:paddingTop="10dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/aprsRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="vertical"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="6dp" android:layout_marginBottom="8dp" android:background="@color/primary_deselected" android:alpha="0.3"/>

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/to_display" android:textColor="@color/primary" android:textSize="16sp" android:fontFamily="@font/jost"/>
                            <EditText android:id="@+id/textChatTo" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:textColor="@color/primary" android:textSize="16sp" android:maxLength="10" android:background="@android:color/transparent" android:textColorHint="@color/primary_deselected" android:hint="@string/callsign_or_cq" android:text="@string/cq" android:imeOptions="actionDone"/>
                            <ImageButton android:id="@+id/singleBeaconButton" android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/ic_pin" android:contentDescription="@string/send_aprs_position_beacond_display" android:onClick="singleBeaconButtonClicked"/>
                        </androidx.appcompat.widget.LinearLayoutCompat>

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <EditText android:id="@+id/textChatInput" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/primary" android:textSize="16sp" android:maxLength="67" android:background="@android:color/transparent" android:textColorHint="@color/primary_deselected" android:hint="@string/write_up_to_67_chars" android:layout_marginEnd="10dp" android:imeOptions="actionSend"/>
                            <FrameLayout android:layout_width="44dp" android:layout_height="44dp">
                                <ImageButton android:id="@+id/sendButton" android:layout_width="28dp" android:layout_height="28dp" android:layout_gravity="center" android:background="@drawable/ic_send" android:contentDescription="@string/send_message_display" android:onClick="sendTextClicked"/>
                                <View android:id="@+id/sendButtonOverlay" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@android:color/transparent" android:onClick="sendButtonOverlayClicked"/>
                            </FrameLayout>
                        </androidx.appcompat.widget.LinearLayoutCompat>

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <!-- Botones de control inferiores (ocultos en landscape) -->
                    <LinearLayout
                        android:id="@+id/voiceModeBottomControls"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- COLUMNA DERECHA: Nav alineada con PTT -->
                <LinearLayout
                    android:layout_width="90dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@color/medium_gray">

                    <com.google.android.material.bottomnavigation.BottomNavigationView
                        android:id="@+id/bottomNavigationView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:menu="@menu/bottom_nav_menu"
                        app:itemTextColor="@color/bottom_nav_text"
                        app:itemIconTint="@color/bottom_nav_icon"
                        app:itemActiveIndicatorStyle="@style/Theme.BottomNavigationView.ActiveIndicator"
                        android:background="@android:color/transparent"
                        app:labelVisibilityMode="labeled"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </FrameLayout>
</layout>
